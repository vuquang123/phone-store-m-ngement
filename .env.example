# ====================================================================
# Mẫu biến môi trường — COPY file này thành .env.local rồi điền giá trị thật.
#   cp .env.example .env.local
# (.env.local đã được .gitignore — KHÔNG commit secrets)
# Sau khi sửa .env.local phải KHỞI ĐỘNG LẠI dev server (pnpm dev).
# ====================================================================

# --- Google Sheets (bắt buộc — nếu thiếu sẽ lỗi /api/login 500 "No key or keyFile set") ---
# Lấy từ file JSON của Service Account (Google Cloud Console > IAM > Service Accounts > Keys).
# Nhớ: chia sẻ (Share) Google Sheet cho đúng email service account này (quyền Editor).

# Trường "client_email" trong JSON service account
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Trường "private_key" trong JSON. Giữ nguyên \n, bọc trong dấu ngoặc kép (1 dòng).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...thay-bang-key-that...==\n-----END PRIVATE KEY-----\n"

# ID của Google Sheet (phần giữa /d/ và /edit trong URL):
# https://docs.google.com/spreadsheets/d/<ĐÂY_LÀ_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=1AbCdEf...thay-bang-id-that

# --- Phiên đăng nhập (BẮT BUỘC — middleware auth) ---
# Khóa ký JWT cookie phiên (tối thiểu 16 ký tự). Sinh ngẫu nhiên:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=thay-bang-chuoi-ngau-nhien-dai

# --- Telegram (tùy chọn — để gửi thông báo đơn hàng) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Topic (message_thread_id) cho Ghi chú bàn giao ca — không set thì mặc định 37551
TELEGRAM_THREAD_NOTE=37551
# Topic nhom "May dang xu ly" (toggle trang thai xu ly may)
TELEGRAM_THREAD_DANG_XU_LY=38062
# (tuỳ chọn) Nếu topic ghi chú nằm ở GROUP KHÁC group mặc định, đặt chat id group đó ở đây.
# Không set thì gửi vào group mặc định (giống các loại đơn khác).
TELEGRAM_CHAT_NOTE=

# --- Webhook nút bấm Telegram (đơn online GHTK "Đã gửi hàng") ---
# Chuỗi bí mật, đặt khi setWebhook; webhook kiểm header x-telegram-bot-api-secret-token === giá trị này.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=
# Domain HTTPS thật để đăng ký webhook (không phải localhost). Dùng 1 trong 2 biến:
PUBLIC_URL=https://domain-that-cua-ban
# NEXT_PUBLIC_SITE_URL=https://domain-that-cua-ban

# --- Public API cho Zalo Mini App (tùy chọn) ---
PUBLIC_API_KEY=
ZALO_PUBLIC_API_KEY=
